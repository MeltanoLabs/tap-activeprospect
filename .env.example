# ActiveProspect Configuration
# Copy this file to .env and fill in your actual values

# Required: ActiveProspect API key (used as Basic Auth password; username is ignored)
TAP_ACTIVEPROSPECT_API_KEY=your_api_key_here

# Optional: earliest record date to sync (ISO 8601)
TAP_ACTIVEPROSPECT_START_DATE=2024-01-01T00:00:00Z
